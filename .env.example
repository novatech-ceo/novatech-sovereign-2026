# NOVATECH — متغيرات البيئة (لا ترفع .env إلى Git)
# انسخ هذا الملف إلى .env وعبّئ القيم. في Vercel: Project → Settings → Environment Variables

# Binance (للخادم فقط — لا تضع BINANCE_SECRET في الواجهة أبداً)
BINANCE_API_KEY=
BINANCE_SECRET=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# جسر الهوية القانونية (كلمة مرور الخزينة)
VAULT_PASSWORD=

# Firebase (اختياري)
FIREBASE_API_KEY=
FIREBASE_PROJECT_ID=
